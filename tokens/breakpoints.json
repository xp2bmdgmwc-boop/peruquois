{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Mobile-first responsive breakpoints. Write styles for mobile first, then layer on min-width queries. Container max-widths prevent content from stretching too wide on large screens.",

  "breakpoint": {
    "sm": {
      "$type": "dimension",
      "$value": "640px",
      "$description": "Large phones / landscape — @media (min-width: 640px)"
    },
    "md": {
      "$type": "dimension",
      "$value": "768px",
      "$description": "Tablets — @media (min-width: 768px)"
    },
    "lg": {
      "$type": "dimension",
      "$value": "1024px",
      "$description": "Small laptops — @media (min-width: 1024px)"
    },
    "xl": {
      "$type": "dimension",
      "$value": "1280px",
      "$description": "Desktops — @media (min-width: 1280px)"
    },
    "2xl": {
      "$type": "dimension",
      "$value": "1536px",
      "$description": "Large desktops — @media (min-width: 1536px)"
    }
  },

  "container": {
    "$description": "Max-width constraints for centered content containers",
    "sm":   { "$type": "dimension", "$value": "640px" },
    "md":   { "$type": "dimension", "$value": "768px" },
    "lg":   { "$type": "dimension", "$value": "1024px" },
    "xl":   { "$type": "dimension", "$value": "1280px" },
    "2xl":  { "$type": "dimension", "$value": "1400px", "$description": "Slightly narrower than breakpoint for breathing room" },
    "prose": { "$type": "dimension", "$value": "65ch", "$description": "Optimal reading width for long-form text" }
  },

  "grid": {
    "$description": "Grid column defaults per breakpoint",
    "columns": {
      "mobile":  { "$type": "number", "$value": 4, "$description": "< 640px" },
      "tablet":  { "$type": "number", "$value": 8, "$description": "640px – 1023px" },
      "desktop": { "$type": "number", "$value": 12, "$description": ">= 1024px" }
    },
    "gutter": {
      "mobile":  { "$type": "dimension", "$value": "16px" },
      "tablet":  { "$type": "dimension", "$value": "24px" },
      "desktop": { "$type": "dimension", "$value": "24px" }
    },
    "margin": {
      "mobile":  { "$type": "dimension", "$value": "16px" },
      "tablet":  { "$type": "dimension", "$value": "32px" },
      "desktop": { "$type": "dimension", "$value": "auto", "$description": "Centered with max-width" }
    }
  },

  "sidebar": {
    "$description": "Common sidebar dimensions",
    "collapsed": { "$type": "dimension", "$value": "64px" },
    "default":   { "$type": "dimension", "$value": "256px" },
    "wide":      { "$type": "dimension", "$value": "320px" }
  },

  "z-index": {
    "$description": "Layering scale — avoids z-index wars",
    "base":       { "$type": "number", "$value": 0 },
    "dropdown":   { "$type": "number", "$value": 10 },
    "sticky":     { "$type": "number", "$value": 20 },
    "fixed":      { "$type": "number", "$value": 30 },
    "overlay":    { "$type": "number", "$value": 40 },
    "modal":      { "$type": "number", "$value": 50 },
    "popover":    { "$type": "number", "$value": 60 },
    "toast":      { "$type": "number", "$value": 70 },
    "tooltip":    { "$type": "number", "$value": 80 }
  }
}