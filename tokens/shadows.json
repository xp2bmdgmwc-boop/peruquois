{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "5-level elevation system. Higher elevation = more prominence. Uses layered shadows for realism.",

  "elevation": {
    "none": {
      "$type": "shadow",
      "$value": "none",
      "$description": "Level 0 — flat, no elevation"
    },
    "sm": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "rgba(0, 0, 0, 0.05)" }
      ],
      "$description": "Level 1 — subtle lift (cards at rest)"
    },
    "md": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "1px", "blur": "3px", "spread": "0px", "color": "rgba(0, 0, 0, 0.1)" },
        { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "-1px", "color": "rgba(0, 0, 0, 0.1)" }
      ],
      "$description": "Level 2 — default elevation (dropdowns, popovers)"
    },
    "lg": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "4px", "blur": "6px", "spread": "-1px", "color": "rgba(0, 0, 0, 0.1)" },
        { "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "-2px", "color": "rgba(0, 0, 0, 0.1)" }
      ],
      "$description": "Level 3 — raised (hover cards, sticky headers)"
    },
    "xl": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "10px", "blur": "15px", "spread": "-3px", "color": "rgba(0, 0, 0, 0.1)" },
        { "offsetX": "0px", "offsetY": "4px", "blur": "6px", "spread": "-4px", "color": "rgba(0, 0, 0, 0.1)" }
      ],
      "$description": "Level 4 — floating (modals, dialogs)"
    },
    "2xl": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "20px", "blur": "25px", "spread": "-5px", "color": "rgba(0, 0, 0, 0.1)" },
        { "offsetX": "0px", "offsetY": "8px", "blur": "10px", "spread": "-6px", "color": "rgba(0, 0, 0, 0.1)" }
      ],
      "$description": "Level 5 — highest prominence (toasts, notifications)"
    }
  },

  "inner": {
    "sm": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "rgba(0, 0, 0, 0.06)", "inset": true }
      ],
      "$description": "Subtle inset — pressed buttons, input fields"
    },
    "md": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "2px", "blur": "4px", "spread": "0px", "color": "rgba(0, 0, 0, 0.08)", "inset": true }
      ],
      "$description": "Medium inset — sunken containers"
    }
  },

  "colored": {
    "$description": "Brand-colored shadows for emphasis — use sparingly",
    "primary": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "4px", "blur": "14px", "spread": "0px", "color": "rgba(37, 99, 235, 0.25)" }
      ],
      "$description": "Blue glow — primary CTA hover"
    },
    "success": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "4px", "blur": "14px", "spread": "0px", "color": "rgba(22, 163, 74, 0.25)" }
      ]
    },
    "error": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "4px", "blur": "14px", "spread": "0px", "color": "rgba(220, 38, 38, 0.25)" }
      ]
    }
  },

  "focus-ring": {
    "$type": "shadow",
    "$value": [
      { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "2px", "color": "#ffffff" },
      { "offsetX": "0px", "offsetY": "0px", "blur": "0px", "spread": "4px", "color": "#3b82f6" }
    ],
    "$description": "Double-ring focus indicator — 2px white + 2px blue. Visible on both light and dark backgrounds. Meets WCAG 2.4.7."
  }
}